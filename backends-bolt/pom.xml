                    <source>${bolt.velox.basedir}/src-iceberg/main/scala</source>
                    <source>${bolt.velox.basedir}/src-iceberg/main/java</source>
                    <source>${bolt.velox.basedir}/src-iceberg${iceberg.binary.version}/main/scala</source>
                    <source>${bolt.velox.basedir}/src-iceberg${iceberg.binary.version}/main/java</source>
                    <source>${bolt.velox.basedir}/src-iceberg-spark${spark.plain.version}/main/scala</source>
                    <source>${bolt.velox.basedir}/src-iceberg-spark${spark.plain.version}/main/java</source>
                  </sources>
                </configuration>
              </execution>
              <execution>
                <id>add-bolt-iceberg-resources</id>
