                    <resource>
                      <directory>${bolt.velox.basedir}/src-delta/main/resources</directory>
                    </resource>
                    <resource>
                      <directory>${bolt.velox.basedir}/src-delta-spark${spark.plain.version}/main/resources</directory>
                    </resource>
                    <resource>
                      <directory>${bolt.velox.basedir}/src-delta${delta.binary.version}/main/resources</directory>
                    </resource>
                    <resource>
                      <directory>${bolt.velox.basedir}/src-delta${delta.binary.version}-spark${spark.plain.version}/main/resources</directory>
                    </resource>
                  </resources>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

